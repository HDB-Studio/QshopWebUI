# ============================================================
# QshopWebUI v5.0 环境配置文件 (PostgreSQL Only)
#
# 使用说明:
#   1. 复制此文件并重命名为 .env（去掉 .example 后缀）
#   2. 根据实际环境修改各参数的值
#   3. 修改配置后，需要重启 Node.js 服务才能生效
#   4. 字符串值不需要加引号，直接写在 = 后面即可
#   5. 注释以 # 开头，# 后请留一个空格以便阅读
#
# 修改 .env 后生效命令: Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force ; node server.js
# ============================================================

# ============================================================
# 1. 数据库位置 / PostgreSQL 连接配置
# ============================================================
#    这些参数指定后端如何连接到 PostgreSQL 数据库。
#    如果数据库运行在另一台服务器，请将 DB_HOST 设置为其 IP 或域名。

# 数据库服务器地址（本机填 localhost，远程填 IP 或域名）
DB_HOST=localhost

# 数据库服务端口（PostgreSQL 默认端口为 5432，如修改过请填入对应值）
DB_PORT=5432

# 数据库登录用户名（默认 postgres，请根据实际数据库配置修改）
DB_USER=postgres

# 数据库登录密码（如果未设置密码可留空，但生产环境强烈建议设置强密码）
DB_PASSWORD=

# 数据库名称（需要事先在 PostgreSQL 中创建此数据库，例如: CREATE DATABASE qshop;）
DB_NAME=qshop


# ============================================================
# 2. 数据库连接池配置
# ============================================================
#    连接池预先建立并维护一定数量的数据库连接，显著提升高并发性能。
#    根据服务器配置和实际负载合理调整这两个值。

# 连接池中保持的最小空闲连接数（默认 5，低并发可降低）
DB_POOL_MIN=5

# 连接池允许的最大连接数（默认 20，高并发可适当提高，但不要超过 PostgreSQL 的 max_connections）
DB_POOL_MAX=20


# ============================================================
# 2.5 Minecraft QSFilterPlugin 服务器连接
# ============================================================
#    通过 HTTP API 连接到运行 Minecraft 服务器上的 QSFilterPlugin 插件。
#    启用后，所有商店数据、价格查询、统计信息均由插件实时提供。
#    QSFilterPlugin API 文档: https://github.com/PikaPikaGFY/QSFilterPlugin

# 是否启用 QSFilterPlugin 真实连接 (true 启用 / false 禁用)
# 启用后，将通过 HTTP 接口连接 Minecraft 服务器，不再使用演示数据
QSFILTER_ENABLED=true

# QSFilterPlugin 服务器基础地址（不包含 /api 路径）
#   - 本地服务器: http://127.0.0.1:8765
#   - 远程服务器: http://192.168.1.100:8765 或 http://mc.example.com:8765
# 默认端口为 8765，如插件配置了其他端口请对应修改
QSFILTER_URL=http://127.0.0.1:8765

# HTTP 请求超时时间（单位: 毫秒，默认 5000 = 5 秒）
# 网络较慢时可适当增大，如 10000 或 15000
QSFILTER_TIMEOUT=5000

# 数据自动同步间隔（单位: 秒，默认 60 = 1 分钟）
# 每隔此时间，后端会自动从 QSFilter 拉取最新数据并刷新缓存
# 设置为 0 禁用自动同步（仅通过 API 调用时实时拉取）
QSFILTER_SYNC_INTERVAL=60

# 最大重试次数（网络请求失败时自动重试）
QSFILTER_MAX_RETRIES=3

# 重试间隔（单位: 毫秒，每次重试间的等待时间）
QSFILTER_RETRY_DELAY=1000


# ============================================================
# 3. 日志位置
# ============================================================
#    指定服务器日志（audit.log 等）保存的目录。
#    留空则默认使用项目根目录下的 logs/ 子目录。

# 日志文件存放目录（绝对路径，如: C:\QshopWebUI\logs 或 /var/log/qshop）
# 留空 = 使用默认位置: <项目目录>/logs/
LOG_DIR=


# ============================================================
# 4. 系统资源限制
# ============================================================
#    用于控制后端服务对系统资源的使用，防止单个应用耗尽服务器资源。
#    建议根据服务器实际配置进行调整:
#      - 小型服务器 (4核/8GB):  DATABASE_MEMORY_LIMIT=1  CPU_CORE_LIMIT=3
#      - 中型服务器 (8核/16GB): DATABASE_MEMORY_LIMIT=4  CPU_CORE_LIMIT=6
#      - 大型服务器 (32核/64GB): DATABASE_MEMORY_LIMIT=16 CPU_CORE_LIMIT=25

# 数据库可使用的最大内存上限（单位: GB，允许小数，例如: 0.5、1、2、4）
# 最小允许值: 0.5 (GB)，低于此值时系统会自动调整为 1 GB
# 建议设置: 不超过服务器物理内存的 50%
DATABASE_MEMORY_LIMIT=1

# 系统可使用的最大 CPU 核心数（整数）
# 留空 = 自动使用服务器总核心数的 80%（推荐，防止 CPU 被占满导致系统无响应）
# 最小允许值: 1，超过系统总核心数时自动调整为总核心数
CPU_CORE_LIMIT=


# ============================================================
# 5. 后端服务器网络配置
# ============================================================

# 后端服务监听的 TCP 端口（默认 3000，如被占用可改为 3001、8080 等）
SERVER_PORT=3000

# 后端服务监听的网络地址
#   0.0.0.0  = 监听所有网络接口，允许从其他机器访问（局域网/公网部署时使用）
#   127.0.0.1 = 仅本机可访问（本地开发时使用，更安全）
SERVER_HOST=0.0.0.0

# 服务器对外公开访问地址（显示在启动信息中，用于浏览器访问）
#   示例: http://mc.example.com:3000 或 http://localhost:3000
PUBLIC_URL=

# Node.js 运行环境标识（开发环境填 development，生产环境填 production）
NODE_ENV=production


# ============================================================
# 6. 安全与认证
# ============================================================
#    本模块实现基于角色的访问控制（RBAC），区分管理员 (admin) 与普通用户 (user)。
#    登录后通过 x-session 请求头携带 session_id 进行认证，session 在 SESSION_TIMEOUT 秒后过期。

# API 访问 Token（可选，用于程序化接口调用，留空则关闭此校验）
# 如果设置了非空值，API 调用时需要在请求头中携带: x-api-token: <此处填写的值>
API_TOKEN=

# 是否启用管理员权限校验
#   true  = 需要管理员登录后才能操作数据管理 / 导入导出功能（推荐，生产环境必须开启）
#   false = 任何人无需登录即可操作所有功能（仅本地调试时使用）
REQUIRE_AUTH=true

# 初始管理员账号用户名（首次启动时写入数据库 users 表，角色为 admin）
# 登录后请在系统中修改为自定义用户名，不要长期使用默认值
ADMIN_USERNAME=admin

# 初始管理员账号密码（请使用强密码，至少 8 位，包含大小写字母和数字）
# 存储时自动使用 bcrypt 哈希，数据库中不会保存明文密码
ADMIN_PASSWORD=

# 用户会话有效期（单位: 秒，默认 3600 秒 = 1 小时）
# 超过此时间后需要重新登录，建议生产环境设置为 1800-7200 秒
SESSION_TIMEOUT=3600


# ============================================================
# 7. 业务参数
# ============================================================

# 单次批量生成测试数据的最大条数（防止误操作生成过多数据拖垮数据库）
# 默认 5,000,000，如需生成更多可临时增大此值
MAX_BATCH_SIZE=5000000

# 列表查询单页允许返回的最大记录数（防止单次查询返回过多数据导致超时）
MAX_PAGE_SIZE=5000

# 列表查询默认每页记录数（12 / 24 / 48 / 60 / 100 等）
DEFAULT_PAGE_SIZE=12

# 搜索关键词最小长度（低于此长度的关键词会被忽略，避免模糊查询全表扫描）
SEARCH_MIN_LENGTH=2

# 是否启用活跃度追踪（true = 记录用户点击/浏览行为统计高热度商店，false = 关闭）
ENABLE_ACTIVITY=true

# 是否启用搜索功能（true = 允许关键词搜索，false = 关闭搜索输入框）
ENABLE_SEARCH=true

# 是否启用分类筛选功能（true = 显示按物品/主人/世界等的筛选下拉，false = 关闭）
ENABLE_FILTER=true

# HTTP 请求体大小上限（防止大文件上传攻击，例如: 5mb / 10mb / 50mb / 100mb）
REQUEST_BODY_LIMIT=10mb


# ============================================================
# 8. PostgreSQL 性能优化开关（高级，了解原理后再修改）
# ============================================================
#    这些开关控制后端是否使用对应的 PostgreSQL 高级特性。
#    通常保持默认即可，如有特殊性能问题可调整测试。

# 是否使用 pg_trgm GIN 索引加速模糊搜索（true = 启用，可提升 LIKE '%xxx%' 查询 5-10 倍性能）
# 需要数据库支持 pg_trgm 扩展（PostgreSQL 自带，执行 CREATE EXTENSION IF NOT EXISTS pg_trgm; 启用）
PG_USE_TRGM=true

# 是否使用 CTE (Common Table Expression) 优化复杂统计查询（true = 启用，大表统计查询更高效）
PG_USE_CTE=true

# 是否使用部分索引扫描高活跃度商店（true = 对热门数据使用专用小索引，查询更聚焦）
PG_USE_PARTIAL_INDEX=true


# ============================================================
# 9. 定时任务与数据同步（高级）
# ============================================================

# 每日全量同步时间（24 小时制，格式: HH:mm，默认 00:00 即凌晨 12 点）
# 可配置多个时间点，用逗号分隔，例如: 00:00,06:00,12:00,18:00
SYNC_SCHEDULE_TIMES=00:00

# 同步失败后自动重试次数（默认 3 次）
SYNC_MAX_RETRIES=3

# 重试间隔（单位: 秒，默认 60 秒）
SYNC_RETRY_INTERVAL=60

# 增量同步（WebHook）是否启用（true/false）
INCREMENTAL_SYNC_ENABLED=true

# WebHook 事件最多延迟（秒，超过则告警，默认 180 = 3 分钟）
WEBHOOK_MAX_LATENCY=180


# ============================================================
# 10. 数据备份与恢复（高级）
# ============================================================

# 是否启用定时自动备份（true/false）
BACKUP_ENABLED=true

# 备份周期（daily = 每日，weekly = 每周，monthly = 每月）
BACKUP_SCHEDULE=daily

# 自动备份时间（24 小时制，格式: HH:mm，默认 02:00 = 凌晨 2 点）
BACKUP_TIME=02:00

# 分钟级备份间隔（1-60 分钟，0 = 不使用分钟级，仅按 BACKUP_TIME 定时触发）
# 例如: 1 = 每分钟自动备份一次，15 = 每 15 分钟一次
# 注意: 每分钟备份会产生大量文件，建议配合适当的保留策略使用
BACKUP_INTERVAL_MINUTES=0

# 备份文件存放目录（绝对路径，例如: C:\QshopWebUI\backups 或 /var/backups/qshop）
# 留空 = 使用默认位置: <项目目录>/backups/
BACKUP_DIR=

# 备份文件命名模板（支持占位符: {type} {date} {time} {ts} {random}）
# 默认: qshop-{type}-{date}-{time}-{random}.json
# 使用时间戳确保每份备份具有唯一文件名，不会相互覆盖
BACKUP_FILE_TEMPLATE=qshop-{type}-{date}-{time}-{random}.json

# 自动清理过期备份（true/false）
BACKUP_CLEANUP_ENABLED=true

# 备份文件保留天数（默认 30 天，超过此天数的旧备份会被自动清理）
BACKUP_RETENTION_DAYS=30

# 保留最近 N 个备份（不论时间，默认 10 个，设置为 0 不启用此规则）
BACKUP_MIN_KEEP=10


# ============================================================
# 11. 统计与监控（高级）
# ============================================================

# 是否启用访问请求统计（true/false，会记录每个 API 请求用于统计分析）
STATS_ENABLED=true

# 统计数据缓存时间（单位: 秒，默认 10 = 10 秒，保证统计数据实时性）
STATS_CACHE_TTL=10

# 是否启用异常告警（true/false，日志中标记 WARN/ERROR 级事件）
ALERT_ENABLED=true


# ============================================================
# 12. 日志输出（高级，管理界面自动设置）
# ============================================================

# HTTP 服务端口（与 SERVER_PORT 功能相同，如两者同时设置，以 PORT 为准）
PORT=3000

# 是否将日志输出到控制台（true = 控制台显示，false = 仅写入文件）
LOG_TO_CONSOLE=true

# 日志级别 (INFO / WARN / ERROR / SILENT)
# INFO = 所有信息 | WARN = 警告及以上 | ERROR = 仅错误 | SILENT = 静默
LOG_LEVEL=INFO

# 是否启用分钟级任务调度（true = 启用定时任务调度器，false = 关闭定时任务）
ALLOCATE_ENABLED=true

# 调度器执行间隔（分钟，默认 5 = 每 5 分钟检查一次定时任务）
ALLOCATE_INTERVAL_MINUTES=5

# 玩家商店单次购买上限（件，防止一次性买空商店）
PLAYER_SHOP_MAX_BUY=500

# 玩家商店库存上限（件，超过后不允许新上架，用于防刷）
PLAYER_SHOP_MAX_STOCK=2000

# 玩家商店低库存告警阈值（件，低于此值的商店会在管理界面高亮）
PLAYER_SHOP_LOW_STOCK_THRESHOLD=10


# ============================================================
# 配置完成，请记得重启 Node.js 服务使修改生效。
# 重启命令: Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force ; node server.js
# ============================================================
