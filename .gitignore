temp/
logs/
reports/
.pnpm-store/

# —— Node.js / npm 运行时 ——
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# —— 依赖锁定（如不想发布可启用）——
# package-lock.json
# yarn.lock

# —— 编辑器与 IDE ——
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

